// {{PROJECT_NAME}} — Jenkins Declarative Pipeline
// Framework: {{FRAMEWORK}} | Language: {{LANGUAGE}}
// Generated by Qlitz Framework Generator

pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
    }

    environment {
        BASE_URL        = credentials('BASE_URL')
        BROWSER         = '{{BROWSER}}'
        HEADLESS        = '{{HEADLESS}}'
    }

    triggers {
        cron('H 2 * * *')   // nightly at ~02:00
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                script {
                    if ('{{LANGUAGE}}' == 'java') {
                        sh 'mvn dependency:resolve -q'
                    } else if ('{{LANGUAGE}}' in ['typescript', 'javascript']) {
                        sh 'npm ci'
                    } else if ('{{LANGUAGE}}' == 'python') {
                        sh 'pip install -r requirements.txt'
                    }
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    if ('{{LANGUAGE}}' == 'java') {
                        sh 'mvn test -B'
                    } else if ('{{LANGUAGE}}' in ['typescript', 'javascript']) {
                        sh 'npm test'
                    } else if ('{{LANGUAGE}}' == 'python') {
                        sh 'pytest --tb=short -v --junitxml=reports/test-results.xml'
                    }
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true,
                  testResults: 'target/surefire-reports/**/*.xml, reports/*.xml'
            archiveArtifacts allowEmptyArchive: true,
                             artifacts: 'target/surefire-reports/**, playwright-report/**, allure-results/**, reports/**'
        }
        failure {
            echo "Pipeline failed for {{PROJECT_NAME}} — check test results."
        }
    }
}
