{
  "name": "{{PROJECT_NAME}}",
  "version": "{{VERSION}}",
  "description": "Playwright hybrid UI + API automation — generated by Qlitz.",
  "scripts": {
    "install:browsers": "playwright install --with-deps",
    "test":           "playwright test",
    "test:ui":        "playwright test --project=ui-chrome",
    "test:ui:ff":     "playwright test --project=ui-firefox",
    "test:api":       "playwright test --project=api",
    "test:smoke":     "playwright test --grep @smoke",
    "test:functional": "playwright test --grep @functional",
    "test:negative":  "playwright test --grep @negative",
    "test:headed":    "playwright test --project=ui-chrome --headed",
    "test:debug":     "playwright test --debug",
    "report":         "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@faker-js/faker":  "^8.4.0",
    "@types/node":      "^20.0.0",
    "typescript":       "^5.4.0"{{REPORTING_DEP}}
  }
}
