{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "commonjs",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "outDir":            "dist",
    "baseUrl":           ".",
    "paths": {
      "@pages/*":    ["src/pages/*"],
      "@fixtures/*": ["src/fixtures/*"]
    }
  },
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
