<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  TestNG parallel suite for {{PROJECT_NAME}}
  Framework: {{FRAMEWORK}} | Language: {{LANGUAGE}}
  Generated by Qlitz Framework Generator
-->
<suite name="{{PROJECT_NAME}} Parallel Suite"
       parallel="{{PARALLEL}}"
       thread-count="{{THREAD_COUNT}}"
       verbose="1">

  <listeners>
    <listener class-name="{{BASE_PACKAGE}}.listeners.RetryListener"/>
  </listeners>

  <test name="Smoke Tests">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <packages>
      <package name="{{BASE_PACKAGE}}.tests"/>
    </packages>
  </test>

  <test name="Regression Tests">
    <groups>
      <run>
        <include name="regression"/>
      </run>
    </groups>
    <packages>
      <package name="{{BASE_PACKAGE}}.tests"/>
    </packages>
  </test>

</suite>
