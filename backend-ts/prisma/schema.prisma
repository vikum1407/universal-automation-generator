// ------------------------------------------------------
//  Datasource & Generator
// ------------------------------------------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------
//  ENUMS
// ------------------------------------------------------
enum ProjectType {
  ui
  api
}

enum RunStatus {
  pending
  running
  passed
  failed
  flaky
  aborted
}

enum RequirementStatus {
  open
  in_progress
  completed
}

enum SuggestionStatus {
  pending
  applied
  rejected
}

enum ReleaseStatus {
  planned
  in_progress
  ready_for_validation
  validating
  ready_to_ship
  shipped
  rolled_back
  cancelled
}

// ------------------------------------------------------
//  PROJECTS
// ------------------------------------------------------
model Project {
  id              String      @id @default(uuid())
  type            ProjectType
  name            String?
  pinned          Boolean     @default(false)
  url             String?
  username        String?
  password        String?
  crawlDepth      Int?
  env             String?
  status          String
  swaggerUrl      String?
  swaggerFilePath String?
  authToken       String?
  createdAt       DateTime    @default(now())

  flows        Flow[]
  endpoints    Endpoint[]
  testRuns     TestRun[]
  requirements Requirement[]
  suggestions  Suggestion[]
  releases     Release[]
  histories    History[]
  analytics    Analytics?
  stability    Stability?
  cloudSync    CloudSync?

  // NEW RELATIONS FOR FLOW ENGINE
  pages       Page[]
  transitions Transition[]

  @@index([type])
  @@index([createdAt])
}

// ------------------------------------------------------
//  FLOWS
// ------------------------------------------------------
model Flow {
  id        String   @id @default(uuid())
  projectId String
  name      String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id])
  endpoints Endpoint[]

  @@index([projectId])
}

// ------------------------------------------------------
//  ENDPOINTS
// ------------------------------------------------------
model Endpoint {
  id        String   @id @default(uuid())
  projectId String
  flowId    String?
  method    String
  path      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  flow    Flow?   @relation(fields: [flowId], references: [id])

  @@index([projectId])
  @@index([flowId])
}

// ------------------------------------------------------
//  PAGE (NEW)
// ------------------------------------------------------
model Page {
  id        String   @id @default(uuid())
  projectId String
  url       String
  title     String?
  createdAt DateTime @default(now())

  project   Project      @relation(fields: [projectId], references: [id])
  fromEdges Transition[] @relation("FromPage")
  toEdges   Transition[] @relation("ToPage")

  @@unique([projectId, url], name: "projectId_url")
  @@index([projectId])
  @@index([url])
}

// ------------------------------------------------------
//  TRANSITION (NEW)
// ------------------------------------------------------
model Transition {
  id        String   @id @default(uuid())
  projectId String
  fromId    String
  toId      String
  action    String
  selector  String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  from    Page    @relation("FromPage", fields: [fromId], references: [id])
  to      Page    @relation("ToPage", fields: [toId], references: [id])

  @@index([projectId])
  @@index([fromId])
  @@index([toId])
}

// ------------------------------------------------------
//  TEST RUNS
// ------------------------------------------------------
model TestRun {
  id         String    @id @default(uuid())
  projectId  String
  testId     String?
  status     RunStatus
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  project Project      @relation(fields: [projectId], references: [id])
  results TestResult[]

  @@index([projectId])
  @@index([status])
}

// ------------------------------------------------------
//  TEST RESULTS
// ------------------------------------------------------
model TestResult {
  id        String   @id @default(uuid())
  runId     String
  step      Int
  message   String?
  passed    Boolean
  createdAt DateTime @default(now())

  run TestRun @relation(fields: [runId], references: [id])

  @@index([runId])
}

// ------------------------------------------------------
//  REQUIREMENTS
// ------------------------------------------------------
model Requirement {
  id          String            @id @default(uuid())
  projectId   String
  title       String
  description String?
  status      RequirementStatus @default(open)
  createdAt   DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

// ------------------------------------------------------
//  SELF-HEALING SUGGESTIONS
// ------------------------------------------------------
model Suggestion {
  id          String           @id @default(uuid())
  projectId   String
  description String
  status      SuggestionStatus @default(pending)
  createdAt   DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

// ------------------------------------------------------
//  RELEASE MANAGEMENT
// ------------------------------------------------------
model Release {
  id           String        @id @default(uuid())
  projectId    String
  name         String?
  version      String?
  environment  String        @default("staging")
  status       ReleaseStatus @default(planned)
  description  String?
  createdBy    String?
  notes        String?
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  project Project       @relation(fields: [projectId], references: [id])
  links   ReleaseLink[]

  @@index([projectId])
  @@index([status])
}

model ReleaseLink {
  id        String   @id @default(uuid())
  releaseId String
  type      String
  targetId  String
  createdAt DateTime @default(now())

  release Release @relation(fields: [releaseId], references: [id])

  @@index([releaseId])
  @@index([type])
}

// ------------------------------------------------------
//  HISTORY
// ------------------------------------------------------
model History {
  id        String   @id @default(uuid())
  projectId String
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

// ------------------------------------------------------
//  ANALYTICS
// ------------------------------------------------------
model Analytics {
  id          String   @id @default(uuid())
  projectId   String   @unique
  passRate    Float?
  failRate    Float?
  flakyRate   Float?
  avgDuration Float?
  lastUpdated DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

// ------------------------------------------------------
//  STABILITY
// ------------------------------------------------------
model Stability {
  id         String   @id @default(uuid())
  projectId  String   @unique
  score      Float?
  readiness  Float?
  guardrails Json?
  updatedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

// ------------------------------------------------------
//  CLOUD SYNC
// ------------------------------------------------------
model CloudSync {
  id           String    @id @default(uuid())
  projectId    String    @unique
  lastUpload   DateTime?
  lastDownload DateTime?
  bucketPath   String?

  project Project @relation(fields: [projectId], references: [id])
}

// ------------------------------------------------------
//  QUALITY BUDGETS
// ------------------------------------------------------
enum BudgetScope {
  org
  project
  release
}

enum BudgetMetric {
  coverageOverall
  coverageCritical
  highRiskUncovered
  failureRate
  flakinessCount
  unstableCriticalFlows
  unstableCriticalEndpoints
  incidentCount
  openCriticalInsights
  unresolvedAISuggestions
}

enum BudgetSeverity {
  soft
  hard
}

model QualityBudget {
  id          String         @id @default(uuid())
  scope       BudgetScope
  scopeId     String
  environment String?
  metric      BudgetMetric
  target      Float?
  limit       Float
  severity    BudgetSeverity
  period      String?
  enabled     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  violations  BudgetViolation[]

  @@index([scope, scopeId])
  @@index([metric])
}

model BudgetViolation {
  id               String         @id @default(uuid())
  budgetId         String
  scope            BudgetScope
  scopeId          String
  environment      String?
  metric           BudgetMetric
  value            Float
  limit            Float
  severity         BudgetSeverity
  occurredAt       DateTime       @default(now())
  resolvedAt       DateTime?
  linkedInsightId  String?

  budget  QualityBudget @relation(fields: [budgetId], references: [id])

  @@index([budgetId])
  @@index([scope, scopeId])
  @@index([occurredAt])
}
